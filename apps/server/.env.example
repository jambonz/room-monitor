# Room Monitor backend configuration

# HTTP/data-WS listen port (frontend connects here)
PORT=3001

# Public ws(s):// URL that MediaJam should dial to deliver the conference
# listen-fork audio. Must be reachable from the jambonz/MediaJam network.
FORK_SINK_URL=ws://localhost:3001/fork

# Optional basic-auth that MediaJam presents on the fork socket (wsAuth)
FORK_SINK_USERNAME=
FORK_SINK_PASSWORD=

# Port the @jambonz/sdk websocket app listens on (jambonz application target)
JAMBONZ_WS_APP_PORT=3002

# Port of the "normal caller" application (/caller). Route a DID to the
# room-monitor-caller application; the room callers join is that application's
# portal-editable ROOM_NAME env var.
CALLER_APP_PORT=4003

# Deepgram (transcription). Key lives only on the backend.
DEEPGRAM_API_KEY=

# wss:// URL of the jambonz SBC the browser's WebRTC SDK registers against
# (e.g. wss://sbc.jambonz.cloud:8443). Sent to the frontend on connect.
WEBRTC_SBC_URL=
