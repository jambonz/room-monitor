# Room Monitor frontend configuration (Vite)

# Data-WebSocket URL of the backend (defaults to ws://<host>:3001/ws)
VITE_DATA_WS_URL=ws://localhost:3001/ws

# Routing target the WebRTC client dials to reach the monitor application.
# The real routing travels in custom SIP headers (X-Room, X-Session-Id, X-Mode);
# this is the dialed address your account routes to the monitor app.
VITE_MONITOR_TARGET=monitor
