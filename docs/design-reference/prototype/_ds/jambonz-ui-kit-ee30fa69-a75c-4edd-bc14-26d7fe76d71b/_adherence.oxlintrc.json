{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": [
          {
            "element": "button",
            "message": "Use <Button> from the design system instead of <button>."
          }
        ]
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/Button/**",
              "components/buttons/ButtonGroup/**",
              "components/icons/Icon/**",
              "components/icons/IconGroup/**",
              "components/jambonz-ui/Tabs/**",
              "components/typography/H1/**",
              "components/typography/H2/**",
              "components/typography/H3/**",
              "components/typography/H4/**",
              "components/typography/H5/**",
              "components/typography/H6/**",
              "components/typography/M/**",
              "components/typography/MS/**",
              "components/typography/MXS/**",
              "components/typography/P/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:objectivityregular|objectivityregular_slanted|objectivitymedium|objectivitymedium_slanted|objectivitybold|objectivitybold_slanted))/i]",
        "message": "Font not provided by the design system. Available: objectivityregular, objectivityregular_slanted, objectivitymedium, objectivitymedium_slanted, objectivitybold, objectivitybold_slanted."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:small|subStyle|mainStyle|ref|className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: small, subStyle, mainStyle, ref, className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='subStyle'] > Literal[value!=/^(?:dark|blue|teal|purple|white|grey)$/]",
        "message": "<Button> subStyle must be one of 'dark' | 'blue' | 'teal' | 'purple' | 'white' | 'grey'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='mainStyle'] > Literal[value!=/^(?:primary|hollow)$/]",
        "message": "<Button> mainStyle must be one of 'primary' | 'hollow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ButtonGroup'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|left|right|key|ref|className|style|children)$/]",
        "message": "<ButtonGroup> doesn't accept that prop. Declared props: className, id, style, children, left, right."
      },
      {
        "selector": "JSXOpeningElement[name.name='H1'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<H1> doesn't accept that prop. Declared props: className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='H2'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<H2> doesn't accept that prop. Declared props: className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='H3'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<H3> doesn't accept that prop. Declared props: className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='H4'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<H4> doesn't accept that prop. Declared props: className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='H5'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<H5> doesn't accept that prop. Declared props: className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='H6'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<H6> doesn't accept that prop. Declared props: className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|subStyle|mainStyle|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: className, id, style, children, subStyle, mainStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='subStyle'] > Literal[value!=/^(?:dark|blue|teal|purple|white|grey)$/]",
        "message": "<Icon> subStyle must be one of 'dark' | 'blue' | 'teal' | 'purple' | 'white' | 'grey'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='mainStyle'] > Literal[value!=/^(?:primary|hollow)$/]",
        "message": "<Icon> mainStyle must be one of 'primary' | 'hollow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconGroup'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<IconGroup> doesn't accept that prop. Declared props: className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='M'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<M> doesn't accept that prop. Declared props: className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='MS'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<MS> doesn't accept that prop. Declared props: className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='MXS'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<MXS> doesn't accept that prop. Declared props: className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='P'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<P> doesn't accept that prop. Declared props: className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|active|key|ref|className|style|children)$/]",
        "message": "<Tabs> doesn't accept that prop. Declared props: children, active."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
